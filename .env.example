DATABASE_URL="file:./dev.db"

# Google Sheets Sync
# Create a Google Cloud Service Account with the Sheets API enabled,
# then share the target spreadsheet with the service account email (Editor access).
#
# ⚠️  SECURITY WARNING: Because this app is built as a static site, these
# NEXT_PUBLIC_ variables are embedded into the JavaScript bundle and are
# therefore visible to anyone who can access the built files.
# To minimise risk:
#   • Restrict the service account to ONLY the specific spreadsheet it needs.
#   • Keep the GitHub repository private, or use another hosting method that
#     protects the built output.
#   • Rotate the private key immediately if it is ever exposed.
NEXT_PUBLIC_GOOGLE_SERVICE_ACCOUNT_EMAIL="your-service-account@project.iam.gserviceaccount.com"
NEXT_PUBLIC_GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
